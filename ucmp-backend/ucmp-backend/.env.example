## UCMP Backend (dev) environment variables
##
## Copy to `.env` (do not commit) and adjust as needed.

# Database
DB_URL=jdbc:postgresql://localhost:5432/ucmpdb
DB_USERNAME=ucmpuser
DB_PASSWORD=securepassword

# JWT
# For production, use a long random value. If you use base64, JwtUtil will decode it.
JWT_SECRET=dev-only-change-me-please-dev-only-change-me-please
JWT_EXPIRATION_MS=86400000

# Seed data
APP_SEED_ENABLED=true

# Spring Security basic user (dev only)
SPRING_SECURITY_USER=admin
SPRING_SECURITY_PASSWORD=temp

